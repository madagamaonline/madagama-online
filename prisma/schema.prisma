// Madagama Pvt Ltd — Retail & Credit Management System
// Prisma schema. Money fields use Decimal(12,2). See PLAN.md for the design rationale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// Auth & configuration
// ----------------------------------------------------------------------------

enum Role {
  ADMIN
  STAFF
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  pin          String?  // 4-digit PIN for quick login switching at the till
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invoicesCreated  Invoice[]       @relation("InvoiceCreatedBy")
  paymentsRecorded Payment[]       @relation("PaymentRecordedBy")
  stockMovements   StockMovement[]
  salesReturns     SalesReturn[]
  shiftReports     ShiftReport[]
}

// Single-row global configuration (id = 1).
model Setting {
  id                   Int      @id @default(1)
  businessName         String   @default("Madagama Pvt Ltd")
  address              String   @default("")
  phone                String   @default("")
  email                String   @default("")
  logoKey              String?
  interestRatePerMonth Decimal  @default("0.02") @db.Decimal(5, 4)
  interestFreeMonths   Int      @default(4)
  smsSenderId          String   @default("Madagama")
  smsEnabled           Boolean  @default(false)
  textlkApiToken       String?
  reminderDayOfMonth   Int      @default(1)
  // Non-taxable kill-switch. When false, the whole system hides every
  // non-taxable product/invoice/report and refuses to create new ones — it
  // behaves as if only taxable stock exists. Nothing is deleted; flipping it
  // back to true restores everything. Default true preserves existing behavior.
  nonTaxableEnabled    Boolean  @default(true)
  updatedAt            DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// Catalog & stock
// ----------------------------------------------------------------------------

model Category {
  id            String        @id @default(cuid())
  name          String
  code          String        @unique // e.g. AGR, ELC
  description   String?
  createdAt     DateTime      @default(now())
  subcategories Subcategory[]
  products      Product[]
}

model Subcategory {
  id         String    @id @default(cuid())
  category   Category  @relation(fields: [categoryId], references: [id])
  categoryId String
  name       String
  code       String // e.g. TOOL, SPRT, TV, PART
  seq        Int       @default(0) // last sequence number used for product codes
  createdAt  DateTime  @default(now())
  products   Product[]

  @@unique([categoryId, code])
}

model Product {
  id                String        @id @default(cuid())
  code              String        @unique // e.g. AGR-TOOL-0001
  name              String
  description       String?
  category          Category      @relation(fields: [categoryId], references: [id])
  categoryId        String
  subcategory       Subcategory   @relation(fields: [subcategoryId], references: [id])
  subcategoryId     String
  costPrice         Decimal       @default("0") @db.Decimal(12, 2)
  sellingPrice      Decimal       @default("0") @db.Decimal(12, 2)
  quantityInStock   Int           @default(0)
  reorderLevel      Int           @default(0)
  taxable           Boolean       @default(true)
  barcode           String?
  primarySupplier   Supplier?     @relation(fields: [primarySupplierId], references: [id])
  primarySupplierId String?
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  invoiceItems   InvoiceItem[]
  purchaseItems  PurchaseItem[]
  stockMovements StockMovement[]
  returnItems    SalesReturnItem[]

  @@index([categoryId])
  @@index([subcategoryId])
}

// ----------------------------------------------------------------------------
// People
// ----------------------------------------------------------------------------

model Customer {
  id          String   @id @default(cuid())
  name        String
  nic         String?
  phone       String
  address     String?
  email       String?
  nicFrontKey String?
  nicBackKey  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoices         Invoice[]
  creditAgreements CreditAgreement[]

  @@index([phone])
}

model Guarantor {
  id          String   @id @default(cuid())
  name        String
  nic         String
  phone       String
  address     String?
  nicFrontKey String?
  nicBackKey  String?
  createdAt   DateTime @default(now())

  creditAgreements CreditAgreement[]
}

model Employee {
  id         String   @id @default(cuid())
  name       String
  nic        String?
  phone      String?
  address    String?
  position   String?  // job role, e.g. Sales Rep / Driver / Helper
  dailyRate  Decimal  @default("0") @db.Decimal(12, 2)
  joinedDate DateTime @default(now())
  pin        String?  // 4-digit PIN for operator switching
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  invoices     Invoice[]
  attendance   Attendance[]
  commissions  Commission[]
  payrollLines PayrollLine[]
  shiftReports ShiftReport[]
}

model ShiftReport {
  id              String    @id @default(cuid())
  employeeId      String?
  employee        Employee? @relation(fields: [employeeId], references: [id])
  createdByUserId String?
  createdBy       User?     @relation(fields: [createdByUserId], references: [id])
  startTime       DateTime
  endTime         DateTime  @default(now())
  expectedCash    Decimal   @db.Decimal(12, 2)
  actualCash      Decimal   @db.Decimal(12, 2)
  discrepancy     Decimal   @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime  @default(now())

  @@index([employeeId])
  @@index([createdAt])
}

model Supplier {
  id            String     @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  createdAt     DateTime   @default(now())

  products  Product[]
  purchases Purchase[]
}

// ----------------------------------------------------------------------------
// Sales / invoicing
// ----------------------------------------------------------------------------

enum InvoiceType {
  CASH
  CREDIT
}

enum InvoiceStatus {
  PAID
  PARTIAL
  CREDIT
}

// Internal classification mirroring the two physical bill books.
enum TaxCategory {
  TAXABLE
  NON_TAXABLE
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  type          InvoiceType   @default(CASH)
  taxCategory   TaxCategory   @default(TAXABLE)
  customer      Customer?     @relation(fields: [customerId], references: [id])
  customerId    String?
  soldBy        Employee?     @relation(fields: [soldByEmployeeId], references: [id])
  soldByEmployeeId String?
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default("0") @db.Decimal(12, 2)
  grandTotal    Decimal       @db.Decimal(12, 2)
  amountPaid    Decimal       @default("0") @db.Decimal(12, 2)
  status        InvoiceStatus @default(PAID)
  notes         String?
  createdBy     User?         @relation("InvoiceCreatedBy", fields: [createdByUserId], references: [id])
  createdByUserId String?
  createdAt     DateTime      @default(now())

  items           InvoiceItem[]
  creditAgreement CreditAgreement?
  returns         SalesReturn[]

  @@index([createdAt])
  @@index([customerId])
  @@index([taxCategory])
  @@index([status])
  @@index([soldByEmployeeId])
  @@index([createdByUserId])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  product     Product? @relation(fields: [productId], references: [id])
  productId   String?
  nameSnapshot String
  codeSnapshot String?
  qty         Int
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)

  @@index([invoiceId])
  @@index([productId])
}

// ----------------------------------------------------------------------------
// Credit engine
// ----------------------------------------------------------------------------

enum CreditStatus {
  ACTIVE
  SETTLED
  DEFAULTED
}

model CreditAgreement {
  id                   String       @id @default(cuid())
  invoice              Invoice      @relation(fields: [invoiceId], references: [id])
  invoiceId            String       @unique
  customer             Customer     @relation(fields: [customerId], references: [id])
  customerId           String
  guarantor            Guarantor    @relation(fields: [guarantorId], references: [id])
  guarantorId          String
  principal            Decimal      @db.Decimal(12, 2)
  startDate            DateTime
  interestRatePerMonth Decimal      @db.Decimal(5, 4) // snapshot at creation
  interestFreeMonths   Int // snapshot at creation
  status               CreditStatus @default(ACTIVE)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  interestCharges InterestCharge[]
  payments        Payment[]

  @@index([status])
  @@index([customerId])
}

model InterestCharge {
  id            String          @id @default(cuid())
  agreement     CreditAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId   String
  period        String // YYYY-MM
  principalBase Decimal         @db.Decimal(12, 2)
  amount        Decimal         @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())

  @@unique([agreementId, period])
}

model Payment {
  id          String          @id @default(cuid())
  agreement   CreditAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId String
  amount      Decimal         @db.Decimal(12, 2)
  paidDate    DateTime        @default(now())
  method      String          @default("CASH")
  note        String?
  recordedBy  User?           @relation("PaymentRecordedBy", fields: [recordedByUserId], references: [id])
  recordedByUserId String?
  createdAt   DateTime        @default(now())

  @@index([agreementId])
  @@index([paidDate])
}

// ----------------------------------------------------------------------------
// Purchasing / supplier credit
// ----------------------------------------------------------------------------

enum PurchaseType {
  CASH
  CREDIT
}

enum PurchaseStatus {
  PAID
  PARTIAL
  CREDIT
}

model Purchase {
  id              String         @id @default(cuid())
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  supplierId      String
  supplierInvoiceNo String?
  date            DateTime       @default(now())
  type            PurchaseType   @default(CASH)
  total           Decimal        @db.Decimal(12, 2)
  amountPaid      Decimal        @default("0") @db.Decimal(12, 2)
  creditDueDate   DateTime?
  status          PurchaseStatus @default(PAID)
  notes           String?
  createdAt       DateTime       @default(now())

  items    PurchaseItem[]
  payments PurchasePayment[]

  @@index([supplierId])
  @@index([creditDueDate])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseId String
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  qty        Int
  costPrice  Decimal  @db.Decimal(12, 2)
  lineTotal  Decimal  @db.Decimal(12, 2)

  @@index([purchaseId])
  @@index([productId])
}

model PurchasePayment {
  id         String   @id @default(cuid())
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseId String
  amount     Decimal  @db.Decimal(12, 2)
  paidDate   DateTime @default(now())
  note       String?
}

// ----------------------------------------------------------------------------
// Payroll & HR
// ----------------------------------------------------------------------------

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

model Attendance {
  id         String           @id @default(cuid())
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
  date       DateTime         @db.Date
  status     AttendanceStatus @default(PRESENT)
  note       String?

  @@unique([employeeId, date])
  @@index([date])
}

model Commission {
  id         String   @id @default(cuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
  amount     Decimal  @db.Decimal(12, 2)
  reason     String
  date       DateTime @default(now())
  invoiceId  String?
  createdAt  DateTime @default(now())

  @@index([employeeId])
  @@index([date])
}

model PayrollRun {
  id          String        @id @default(cuid())
  period      String        @unique // YYYY-MM
  generatedAt DateTime      @default(now())
  lines       PayrollLine[]
}

model PayrollLine {
  id               String     @id @default(cuid())
  run              PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId            String
  employee         Employee   @relation(fields: [employeeId], references: [id])
  employeeId       String
  daysWorked       Decimal    @db.Decimal(6, 1)
  dailyRate        Decimal    @db.Decimal(12, 2)
  baseSalary       Decimal    @db.Decimal(12, 2)
  commissionsTotal Decimal    @default("0") @db.Decimal(12, 2)
  deductions       Decimal    @default("0") @db.Decimal(12, 2)
  netPay           Decimal    @db.Decimal(12, 2)
}

// ----------------------------------------------------------------------------
// Finance & ops
// ----------------------------------------------------------------------------

model Expense {
  id            String   @id @default(cuid())
  category      String // rent, utilities, bills, salaries, misc
  amount        Decimal  @db.Decimal(12, 2)
  date          DateTime @default(now())
  description   String?
  attachmentKey String?
  createdAt     DateTime @default(now())

  @@index([date])
  @@index([category])
}

enum NotificationType {
  CUSTOMER_PAYMENT
  INTEREST_WARNING
  SUPPLIER_CREDIT
  ADMIN_DIGEST
}

enum NotificationStatus {
  SENT
  FAILED
}

model NotificationLog {
  id        String             @id @default(cuid())
  type      NotificationType
  refId     String? // agreement id, purchase id, etc.
  dedupeKey String?            @unique // prevents duplicate sends per period
  channel   String             @default("SMS")
  recipient String
  message   String
  status    NotificationStatus @default(SENT)
  error     String?
  sentAt    DateTime           @default(now())

  @@index([type])
  @@index([sentAt])
}

// ----------------------------------------------------------------------------
// Stock audit & returns
// ----------------------------------------------------------------------------

enum StockMovementType {
  OPENING
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
}

// One row per change to a product's stock — the audit trail.
model StockMovement {
  id              String            @id @default(cuid())
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId       String
  type            StockMovementType
  qty             Int // signed: positive = stock in, negative = stock out
  balanceAfter    Int // stock level immediately after this movement
  reason          String?
  refId           String? // invoice / purchase / return id
  createdBy       User?             @relation(fields: [createdByUserId], references: [id])
  createdByUserId String?
  createdAt       DateTime          @default(now())

  @@index([productId])
  @@index([createdAt])
}

model SalesReturn {
  id              String   @id @default(cuid())
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])
  invoiceId       String?
  date            DateTime @default(now())
  totalRefund     Decimal  @db.Decimal(12, 2)
  method          String   @default("CASH")
  reason          String?
  createdBy       User?    @relation(fields: [createdByUserId], references: [id])
  createdByUserId String?
  createdAt       DateTime @default(now())

  items SalesReturnItem[]

  @@index([invoiceId])
  @@index([createdAt])
}

model SalesReturnItem {
  id        String      @id @default(cuid())
  return    SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  returnId  String
  product   Product     @relation(fields: [productId], references: [id])
  productId String
  qty       Int
  unitPrice Decimal     @db.Decimal(12, 2)
  lineTotal Decimal     @db.Decimal(12, 2)

  @@index([returnId])
}
