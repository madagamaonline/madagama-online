// Madagama Pvt Ltd — Retail & Credit Management System
// Prisma schema. Money fields use Decimal(12,2). See PLAN.md for the design rationale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// Auth & configuration
// ----------------------------------------------------------------------------

enum Role {
  ADMIN
  STAFF
  SALESPERSON
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  pin          String? // 4-digit PIN for quick login switching at the till
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invoicesCreated             Invoice[]                        @relation("InvoiceCreatedBy")
  invoicesVoided              Invoice[]                        @relation("InvoiceVoidedBy")
  paymentsRecorded            Payment[]                        @relation("PaymentRecordedBy")
  stockMovements              StockMovement[]
  salesReturns                SalesReturn[]
  supplierReturns             SupplierReturn[]
  shiftReports                ShiftReport[]
  serviceJobs                 ServiceJob[]
  serviceJobEvents            ServiceJobEvent[]
  priceChanges                PriceChange[]
  quotations                  Quotation[]
  customerRequestsCreated     CustomerRequest[]                @relation("CustomerRequestCreatedBy")
  customerRequestsAssigned    CustomerRequest[]                @relation("CustomerRequestAssignedTo")
  customerRequestEvents       CustomerRequestEvent[]
  lolcReceiptsCreated         LolcReceipt[]                    @relation("LolcReceiptCreatedBy")
  lolcReceiptsRemitted        LolcReceipt[]                    @relation("LolcReceiptRemittedBy")
  lolcReceiptsConfirmed       LolcReceipt[]                    @relation("LolcReceiptConfirmedBy")
  lolcReceiptsVoided          LolcReceipt[]                    @relation("LolcReceiptVoidedBy")
  lolcReceiptEvents           LolcReceiptEvent[]               @relation("LolcReceiptEventActor")
  consignmentVehiclesReceived ConsignmentVehicle[]             @relation("VehicleReceivedBy")
  vehicleSalesCreated         VehicleSale[]                    @relation("VehicleSaleCreatedBy")
  vehicleSalesVoided          VehicleSale[]                    @relation("VehicleSaleVoidedBy")
  vehicleCustomerPayments     VehicleCustomerPayment[]
  vehicleSupplierSettlements  VehicleSupplierSettlement[]
  vehicleDocumentEvents       VehicleDocumentEvent[]
  vehicleDocumentItemsUpdated VehicleDocumentItem[]            @relation("VehicleDocumentItemUpdatedBy")
  vehicleAcknowledgements     VehicleDocumentAcknowledgement[]
}

// Single-row global configuration (id = 1).
model Setting {
  id                     Int      @id @default(1)
  businessName           String   @default("Madagama Pvt Ltd")
  address                String   @default("")
  phone                  String   @default("")
  email                  String   @default("")
  logoKey                String?
  interestRatePerMonth   Decimal  @default("0.02") @db.Decimal(5, 4)
  interestFreeMonths     Int      @default(4)
  // EPF/ETF contribution rates (fractions, e.g. 0.08 = 8%). Sri Lanka defaults:
  // EPF employee 8% (deducted), EPF employer 12% + ETF 3% (employer cost).
  epfEmployeeRate        Decimal  @default("0.08") @db.Decimal(6, 4)
  epfEmployerRate        Decimal  @default("0.12") @db.Decimal(6, 4)
  etfRate                Decimal  @default("0.03") @db.Decimal(6, 4)
  smsSenderId            String   @default("Madagama")
  smsEnabled             Boolean  @default(false)
  textlkApiToken         String?
  reminderDayOfMonth     Int      @default(1)
  // Non-taxable kill-switch. When false, the whole system hides every
  // non-taxable product/invoice/report and refuses to create new ones — it
  // behaves as if only taxable stock exists. Nothing is deleted; flipping it
  // back to true restores everything. Default true preserves existing behavior.
  nonTaxableEnabled      Boolean  @default(true)
  // Default target gross margin (%) used by the pricing helper / bulk re-pricer
  // when a product has no per-item targetMarginPct of its own.
  defaultTargetMarginPct Decimal  @default("20") @db.Decimal(5, 2)
  updatedAt              DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// Catalog & stock
// ----------------------------------------------------------------------------

model Category {
  id            String        @id @default(cuid())
  name          String
  code          String        @unique // e.g. AGR, ELC
  description   String?
  // Last sequence used for products filed directly under this category with no
  // subcategory — produces codes like AGR-0001. Subcategorised products use
  // Subcategory.seq instead.
  seq           Int           @default(0)
  createdAt     DateTime      @default(now())
  subcategories Subcategory[]
  products      Product[]
}

model Subcategory {
  id         String    @id @default(cuid())
  category   Category  @relation(fields: [categoryId], references: [id])
  categoryId String
  name       String
  code       String // e.g. TOOL, SPRT, TV, PART
  seq        Int       @default(0) // last sequence number used for product codes
  createdAt  DateTime  @default(now())
  products   Product[]

  @@unique([categoryId, code])
}

model Product {
  id                String       @id @default(cuid())
  code              String       @unique // e.g. AGR-TOOL-0001
  // Short sticker code (#1, #2, …) — global sequence, printed on the physical
  // item so the cashier can type just the number at the till.
  shortCode         Int          @unique @default(autoincrement())
  name              String
  description       String?
  category          Category     @relation(fields: [categoryId], references: [id])
  categoryId        String
  subcategory       Subcategory? @relation(fields: [subcategoryId], references: [id])
  subcategoryId     String?
  costPrice         Decimal      @default("0") @db.Decimal(12, 2)
  sellingPrice      Decimal      @default("0") @db.Decimal(12, 2)
  // Target gross margin (on selling price) for this product. Null = fall back
  // to Setting.defaultTargetMarginPct. Drives the pricing helper + bulk re-pricer.
  targetMarginPct   Decimal?     @db.Decimal(5, 2)
  quantityInStock   Int          @default(0)
  reorderLevel      Int          @default(0)
  taxable           Boolean      @default(true)
  barcode           String?
  // Manufacturer identifiers, mainly for electronics (searchable at the POS).
  modelNumber       String?
  serialNumber      String?
  primarySupplier   Supplier?    @relation(fields: [primarySupplierId], references: [id])
  primarySupplierId String?
  active            Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  invoiceItems        InvoiceItem[]
  purchaseItems       PurchaseItem[]
  stockMovements      StockMovement[]
  returnItems         SalesReturnItem[]
  supplierReturnItems SupplierReturnItem[]
  priceChanges        PriceChange[]
  quotationItems      QuotationItem[]
  customerRequests    CustomerRequest[]

  @@index([categoryId])
  @@index([subcategoryId])
}

// ----------------------------------------------------------------------------
// People
// ----------------------------------------------------------------------------

model Customer {
  id          String   @id @default(cuid())
  name        String
  nic         String?
  phone       String
  address     String?
  email       String?
  nicFrontKey String?
  nicBackKey  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoices         Invoice[]
  creditAgreements CreditAgreement[]
  serviceJobs      ServiceJob[]
  quotations       Quotation[]
  customerRequests CustomerRequest[]
  vehicleSales     VehicleSale[]

  @@index([phone])
}

model Guarantor {
  id          String   @id @default(cuid())
  name        String
  nic         String
  phone       String
  address     String?
  nicFrontKey String?
  nicBackKey  String?
  createdAt   DateTime @default(now())

  creditAgreements CreditAgreement[]
}

model Employee {
  id           String   @id @default(cuid())
  name         String
  nic          String?
  phone        String?
  address      String?
  position     String? // job role, e.g. Sales Rep / Driver / Helper
  dailyRate    Decimal  @default("0") @db.Decimal(12, 2)
  joinedDate   DateTime @default(now())
  pin          String? // 4-digit PIN for operator switching
  active       Boolean  @default(true)
  // EPF/ETF membership. Only members get statutory deductions/contributions
  // (casual/daily helpers are typically not registered). epfNumber is the
  // member's EPF reference for remittance.
  epfEtfMember Boolean  @default(false)
  epfNumber    String?
  createdAt    DateTime @default(now())

  invoices     Invoice[]
  attendance   Attendance[]
  commissions  Commission[]
  overtime     Overtime[]
  advances     SalaryAdvance[]
  payrollLines PayrollLine[]
  shiftReports ShiftReport[]
  quotations   Quotation[]
  vehicleSales VehicleSale[]
}

model ShiftReport {
  id              String    @id @default(cuid())
  employeeId      String?
  employee        Employee? @relation(fields: [employeeId], references: [id])
  createdByUserId String?
  createdBy       User?     @relation(fields: [createdByUserId], references: [id])
  startTime       DateTime
  endTime         DateTime  @default(now())
  expectedCash    Decimal   @db.Decimal(12, 2)
  actualCash      Decimal   @db.Decimal(12, 2)
  discrepancy     Decimal   @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime  @default(now())

  @@index([employeeId])
  @@index([createdAt])
}

model Supplier {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  createdAt     DateTime @default(now())

  products                   Product[]
  purchases                  Purchase[]
  returns                    SupplierReturn[]
  customerRequests           CustomerRequest[]
  issuedCheques              IssuedCheque[]
  consignmentVehicles        ConsignmentVehicle[]
  vehicleSupplierSettlements VehicleSupplierSettlement[]
}

// ----------------------------------------------------------------------------
// Supplier-owned consignment vehicles
// ----------------------------------------------------------------------------

enum VehicleKind {
  TRACTOR
  HARVESTER
  COMBINE_HARVESTER
}

enum ConsignmentVehicleStatus {
  DRAFT
  AVAILABLE
  RESERVED
  SOLD
  RETURNED
}

enum VehicleSaleType {
  CASH
  EXTERNAL_FINANCE
  IN_HOUSE_CREDIT
}

enum VehicleSaleStatus {
  CONFIRMED
  VOIDED
}

enum VehiclePaymentKind {
  FULL_PAYMENT
  DOWN_PAYMENT
  INSTALLMENT
  FINAL_SETTLEMENT
}

enum VehiclePaymentMethod {
  CASH
  BANK
  CHEQUE
  CARD
}

enum VehicleCreditStatus {
  ACTIVE
  SETTLED
  DEFAULTED
  VOIDED
}

enum VehicleDocumentCaseStatus {
  AWAITING_CUSTOMER_DOCUMENTS
  DOCUMENTS_RECEIVED
  SUBMITTED
  PROCESSING
  REGISTERED
  HANDED_OVER
  CANCELLED
}

enum VehicleDocumentItemStatus {
  REQUIRED
  RECEIVED
  SUBMITTED
  APPROVED
  RETURNED
  WAIVED
}

enum VehicleDocumentEventType {
  CASE_CREATED
  DOCUMENT_ADDED
  STATUS_CHANGED
  CUSTOMER_DOCUMENTS_RECEIVED
  REGISTRATION_DOCUMENTS_HANDED_OVER
  NOTE
}

enum VehicleAcknowledgementType {
  CUSTOMER_DOCUMENTS_RECEIVED
  REGISTRATION_DOCUMENTS_HANDED_OVER
}

model ConsignmentVehicle {
  id                    String                   @id @default(cuid())
  vehicleNumber         Int                      @unique @default(autoincrement())
  kind                  VehicleKind
  make                  String
  model                 String
  year                  Int?
  colour                String?
  engineNumber          String                   @unique
  chassisNumber         String                   @unique
  specifications        String?
  photoKeys             String[]                 @default([])
  supplier              Supplier                 @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierId            String
  supplierReference     String?
  listPrice             Decimal                  @db.Decimal(12, 2)
  supplierSettlementDue Decimal                  @db.Decimal(12, 2)
  status                ConsignmentVehicleStatus @default(AVAILABLE)
  receivedAt            DateTime                 @default(now())
  receivedBy            User?                    @relation("VehicleReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  receivedByUserId      String?
  notes                 String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  sales VehicleSale[]

  @@index([supplierId, status])
  @@index([status, receivedAt])
}

model VehicleSale {
  id               String             @id @default(cuid())
  saleNumber       Int                @unique @default(autoincrement())
  vehicle          ConsignmentVehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  vehicleId        String
  customer         Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerId       String
  soldBy           Employee?          @relation(fields: [soldByEmployeeId], references: [id], onDelete: SetNull)
  soldByEmployeeId String?
  type             VehicleSaleType
  status           VehicleSaleStatus  @default(CONFIRMED)
  saleDate         DateTime           @default(now())

  vehicleLabelSnapshot  String
  engineNumberSnapshot  String
  chassisNumberSnapshot String
  supplierNameSnapshot  String
  listPrice             Decimal @db.Decimal(12, 2)
  supplierSettlementDue Decimal @db.Decimal(12, 2)
  grossDealerCommission Decimal @db.Decimal(12, 2)
  customerDiscount      Decimal @default("0") @db.Decimal(12, 2)
  customerPrice         Decimal @db.Decimal(12, 2)
  netDealerCommission   Decimal @db.Decimal(12, 2)
  customerCollected     Decimal @default("0") @db.Decimal(12, 2)
  supplierPaid          Decimal @default("0") @db.Decimal(12, 2)
  lossOverrideReason    String?

  financeProvider       String?
  financeReference      String?
  financeApprovedAmount Decimal?  @db.Decimal(12, 2)
  financeApprovedAt     DateTime?
  notes                 String?

  createdBy       User?     @relation("VehicleSaleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdAt       DateTime  @default(now())
  voidedAt        DateTime?
  voidReason      String?
  voidedBy        User?     @relation("VehicleSaleVoidedBy", fields: [voidedByUserId], references: [id], onDelete: SetNull)
  voidedByUserId  String?

  payments            VehicleCustomerPayment[]
  creditAgreement     VehicleCreditAgreement?
  supplierSettlements VehicleSupplierSettlement[]
  documentCase        VehicleDocumentCase?

  @@index([vehicleId, status])
  @@index([customerId, saleDate])
  @@index([type, status])
}

model VehicleCustomerPayment {
  id               String               @id @default(cuid())
  receiptNumber    Int                  @unique @default(autoincrement())
  sale             VehicleSale          @relation(fields: [saleId], references: [id], onDelete: Restrict)
  saleId           String
  kind             VehiclePaymentKind
  amount           Decimal              @db.Decimal(12, 2)
  method           VehiclePaymentMethod @default(CASH)
  reference        String?
  note             String?
  paidDate         DateTime             @default(now())
  recordedBy       User?                @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)
  recordedByUserId String?
  createdAt        DateTime             @default(now())

  @@index([saleId, paidDate])
}

model VehicleCreditAgreement {
  id                   String              @id @default(cuid())
  sale                 VehicleSale         @relation(fields: [saleId], references: [id], onDelete: Restrict)
  saleId               String              @unique
  principal            Decimal             @db.Decimal(12, 2)
  startDate            DateTime
  firstDueDate         DateTime?
  termMonths           Int?
  expectedInstallment  Decimal?            @db.Decimal(12, 2)
  interestRatePerMonth Decimal             @default("0") @db.Decimal(5, 4)
  interestFreeMonths   Int                 @default(0)
  guarantorName        String?
  guarantorNic         String?
  guarantorPhone       String?
  status               VehicleCreditStatus @default(ACTIVE)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([status, firstDueDate])
}

model VehicleSupplierSettlement {
  id               String               @id @default(cuid())
  sale             VehicleSale          @relation(fields: [saleId], references: [id], onDelete: Restrict)
  saleId           String
  supplier         Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierId       String
  amount           Decimal              @db.Decimal(12, 2)
  method           VehiclePaymentMethod @default(BANK)
  reference        String?
  note             String?
  paidDate         DateTime             @default(now())
  recordedBy       User?                @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)
  recordedByUserId String?
  createdAt        DateTime             @default(now())

  @@index([saleId, paidDate])
  @@index([supplierId, paidDate])
}

model VehicleDocumentCase {
  id                  String                    @id @default(cuid())
  sale                VehicleSale               @relation(fields: [saleId], references: [id], onDelete: Restrict)
  saleId              String                    @unique
  status              VehicleDocumentCaseStatus @default(AWAITING_CUSTOMER_DOCUMENTS)
  registrationNumber  String?
  processingReference String?
  submittedAt         DateTime?
  registeredAt        DateTime?
  handedOverAt        DateTime?
  notes               String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  items            VehicleDocumentItem[]
  events           VehicleDocumentEvent[]
  acknowledgements VehicleDocumentAcknowledgement[]

  @@index([status, updatedAt])
}

model VehicleDocumentItem {
  id              String                    @id @default(cuid())
  case            VehicleDocumentCase       @relation(fields: [caseId], references: [id], onDelete: Restrict)
  caseId          String
  name            String
  status          VehicleDocumentItemStatus @default(REQUIRED)
  required        Boolean                   @default(true)
  fileKey         String?
  reference       String?
  receivedAt      DateTime?
  submittedAt     DateTime?
  returnedAt      DateTime?
  waiverReason    String?
  updatedBy       User?                     @relation("VehicleDocumentItemUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  updatedByUserId String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([caseId, status])
}

model VehicleDocumentEvent {
  id              String                     @id @default(cuid())
  case            VehicleDocumentCase        @relation(fields: [caseId], references: [id], onDelete: Restrict)
  caseId          String
  type            VehicleDocumentEventType
  fromStatus      VehicleDocumentCaseStatus?
  toStatus        VehicleDocumentCaseStatus?
  note            String?
  createdBy       User?                      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdAt       DateTime                   @default(now())

  @@index([caseId, createdAt])
}

model VehicleDocumentAcknowledgement {
  id                  String                     @id @default(cuid())
  case                VehicleDocumentCase        @relation(fields: [caseId], references: [id], onDelete: Restrict)
  caseId              String
  type                VehicleAcknowledgementType
  signerName          String
  signerNic           String
  signatureKey        String
  acknowledgementText String
  documentManifest    Json
  manifestHash        String
  signedAt            DateTime                   @default(now())
  witnessedBy         User?                      @relation(fields: [witnessedByUserId], references: [id], onDelete: SetNull)
  witnessedByUserId   String?
  createdAt           DateTime                   @default(now())

  @@unique([caseId, type])
  @@index([caseId, signedAt])
}

// ----------------------------------------------------------------------------
// Customer product enquiries and special requests
// ----------------------------------------------------------------------------

enum CustomerRequestType {
  PRODUCT_INQUIRY
  IMPORT_REQUEST
  PRICE_INQUIRY
  OTHER
}

enum CustomerRequestPriority {
  LOW
  NORMAL
  HIGH
}

enum CustomerRequestStatus {
  NEW
  SEARCHING
  ORDERED
  ARRIVED
  CONTACTED
  COMPLETED
  CANCELLED
}

model CustomerRequest {
  id            String                  @id @default(cuid())
  requestNumber Int                     @unique @default(autoincrement())
  title         String
  type          CustomerRequestType     @default(PRODUCT_INQUIRY)
  description   String?
  quantity      Int                     @default(1)
  budget        Decimal?                @db.Decimal(12, 2)
  priority      CustomerRequestPriority @default(NORMAL)
  status        CustomerRequestStatus   @default(NEW)

  customer     Customer? @relation(fields: [customerId], references: [id])
  customerId   String?
  contactName  String?
  contactPhone String?
  product      Product?  @relation(fields: [productId], references: [id])
  productId    String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  supplierId   String?

  assignedTo       User   @relation("CustomerRequestAssignedTo", fields: [assignedToUserId], references: [id])
  assignedToUserId String
  createdBy        User   @relation("CustomerRequestCreatedBy", fields: [createdByUserId], references: [id])
  createdByUserId  String

  followUpAt          DateTime?
  expectedArrivalDate DateTime?
  remindBySms         Boolean                @default(false)
  completedAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  events              CustomerRequestEvent[]

  @@index([status, followUpAt])
  @@index([assignedToUserId, status])
  @@index([customerId])
  @@index([productId])
}

model CustomerRequestEvent {
  id              String                 @id @default(cuid())
  request         CustomerRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId       String
  fromStatus      CustomerRequestStatus?
  toStatus        CustomerRequestStatus
  note            String?
  createdBy       User                   @relation(fields: [createdByUserId], references: [id])
  createdByUserId String
  createdAt       DateTime               @default(now())

  @@index([requestId, createdAt])
}

// ----------------------------------------------------------------------------
// LOLC custodial collections (operational tracking only; deliberately off-ledger)
// ----------------------------------------------------------------------------

enum LolcReceiptStatus {
  COLLECTED
  MCASH_SENT
  NEEDS_ATTENTION
  LOLC_CONFIRMED
  VOIDED
}

enum LolcReceiptEventType {
  CREATED
  MCASH_SENT
  ISSUE_REPORTED
  LOLC_CONFIRMED
  VOIDED
}

model LolcReceipt {
  id                        String             @id @default(cuid())
  receiptNumber             Int                @unique @default(autoincrement())
  submissionKey             String             @unique
  customerName              String
  customerPhone             String
  lolcCode                  String
  amount                    Decimal            @db.Decimal(12, 2)
  collectedAt               DateTime
  note                      String?
  status                    LolcReceiptStatus  @default(COLLECTED)
  mCashReference            String?
  remittedAt                DateTime?
  remittedByUserId          String?
  remittedBy                User?              @relation("LolcReceiptRemittedBy", fields: [remittedByUserId], references: [id], onDelete: SetNull)
  lolcConfirmationReference String?
  confirmedAt               DateTime?
  confirmedByUserId         String?
  confirmedBy               User?              @relation("LolcReceiptConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  issueNote                 String?
  createdByUserId           String?
  createdBy                 User?              @relation("LolcReceiptCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  voidReason                String?
  voidedAt                  DateTime?
  voidedByUserId            String?
  voidedBy                  User?              @relation("LolcReceiptVoidedBy", fields: [voidedByUserId], references: [id], onDelete: SetNull)
  events                    LolcReceiptEvent[]

  @@index([status, collectedAt])
  @@index([lolcCode])
  @@index([customerPhone])
  @@index([mCashReference])
}

model LolcReceiptEvent {
  id             String               @id @default(cuid())
  receiptId      String
  receipt        LolcReceipt          @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  type           LolcReceiptEventType
  fromStatus     LolcReceiptStatus?
  toStatus       LolcReceiptStatus
  reference      String?
  note           String?
  occurredAt     DateTime
  actorUserId    String?
  actor          User?                @relation("LolcReceiptEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  idempotencyKey String?              @unique
  createdAt      DateTime             @default(now())

  @@index([receiptId, occurredAt])
}

// ----------------------------------------------------------------------------
// Sales / invoicing
// ----------------------------------------------------------------------------

enum InvoiceType {
  CASH
  CREDIT
}

enum InvoiceStatus {
  PAID
  PARTIAL
  CREDIT
}

// Internal classification mirroring the two physical bill books.
enum TaxCategory {
  TAXABLE
  NON_TAXABLE
}

model Invoice {
  id               String        @id @default(cuid())
  invoiceNumber    String        @unique
  type             InvoiceType   @default(CASH)
  taxCategory      TaxCategory   @default(TAXABLE)
  customer         Customer?     @relation(fields: [customerId], references: [id])
  customerId       String?
  soldBy           Employee?     @relation(fields: [soldByEmployeeId], references: [id])
  soldByEmployeeId String?
  subtotal         Decimal       @db.Decimal(12, 2)
  discount         Decimal       @default("0") @db.Decimal(12, 2)
  grandTotal       Decimal       @db.Decimal(12, 2)
  amountPaid       Decimal       @default("0") @db.Decimal(12, 2)
  status           InvoiceStatus @default(PAID)
  notes            String?
  createdBy        User?         @relation("InvoiceCreatedBy", fields: [createdByUserId], references: [id])
  createdByUserId  String?
  createdAt        DateTime      @default(now())
  voidedAt         DateTime?
  voidReason       String?
  voidedBy         User?         @relation("InvoiceVoidedBy", fields: [voidedByUserId], references: [id], onDelete: SetNull)
  voidedByUserId   String?

  items           InvoiceItem[]
  creditAgreement CreditAgreement?
  returns         SalesReturn[]
  serviceJobs     ServiceJob[]

  @@index([createdAt])
  @@index([customerId])
  @@index([taxCategory])
  @@index([status])
  @@index([soldByEmployeeId])
  @@index([createdByUserId])
  @@index([voidedAt])
  @@index([voidedByUserId])
}

model InvoiceItem {
  id           String   @id @default(cuid())
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId    String
  product      Product? @relation(fields: [productId], references: [id])
  productId    String?
  nameSnapshot String
  codeSnapshot String?
  qty          Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)
  // Product cost at the moment of sale, captured so profit reports stay correct
  // even after the product's cost later changes (WAC / bulk re-pricing). Null on
  // rows created before this field existed — reports fall back to current cost.
  costSnapshot Decimal? @db.Decimal(12, 2)

  @@index([invoiceId])
  @@index([productId])
}

// ----------------------------------------------------------------------------
// Quotations — formal price quotes to customers. NOT a sale: no stock moves, no
// invoice numbering. Lines can be catalog products or free-text (e.g. spec'd
// solar pumps), mirroring the paper quotation book.
// ----------------------------------------------------------------------------

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String          @unique // QUO-000001
  status          QuotationStatus @default(DRAFT)

  // Optional customer link; falls back to typed fields for a prospect / walk-in,
  // matching the paper form's Customer Name / Address header.
  customer     Customer? @relation(fields: [customerId], references: [id])
  customerId   String?
  customerName String? // typed name when no account is linked
  address      String?
  phone        String?
  branch       String?

  subtotal   Decimal   @db.Decimal(12, 2)
  discount   Decimal   @default("0") @db.Decimal(12, 2)
  grandTotal Decimal   @db.Decimal(12, 2)
  notes      String?
  validUntil DateTime?

  soldBy           Employee? @relation(fields: [soldByEmployeeId], references: [id])
  soldByEmployeeId String?
  createdBy        User?     @relation(fields: [createdByUserId], references: [id])
  createdByUserId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  items QuotationItem[]

  @@index([createdAt])
  @@index([customerId])
  @@index([status])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String

  // Optional link to a catalog product (a line can also be fully free-text).
  product     Product? @relation(fields: [productId], references: [id])
  productId   String?
  model       String? // free text, e.g. "2x2-2HP" (or the product code)
  name        String // item name / heading
  description String? // multi-line "Product Details"
  qty         Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  lineTotal   Decimal  @db.Decimal(12, 2)

  @@index([quotationId])
  @@index([productId])
}

// ----------------------------------------------------------------------------
// Credit engine
// ----------------------------------------------------------------------------

enum CreditStatus {
  ACTIVE
  SETTLED
  DEFAULTED
  VOIDED
}

model CreditAgreement {
  id                   String       @id @default(cuid())
  invoice              Invoice      @relation(fields: [invoiceId], references: [id])
  invoiceId            String       @unique
  customer             Customer     @relation(fields: [customerId], references: [id])
  customerId           String
  guarantor            Guarantor?   @relation(fields: [guarantorId], references: [id])
  guarantorId          String?
  principal            Decimal      @db.Decimal(12, 2)
  startDate            DateTime
  interestRatePerMonth Decimal      @db.Decimal(5, 4) // snapshot at creation
  interestFreeMonths   Int // snapshot at creation
  status               CreditStatus @default(ACTIVE)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  interestCharges InterestCharge[]
  payments        Payment[]

  @@index([status])
  @@index([customerId])
}

model InterestCharge {
  id            String          @id @default(cuid())
  agreement     CreditAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId   String
  period        String // YYYY-MM
  principalBase Decimal         @db.Decimal(12, 2)
  amount        Decimal         @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())

  @@unique([agreementId, period])
}

model Payment {
  id               String          @id @default(cuid())
  agreement        CreditAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId      String
  amount           Decimal         @db.Decimal(12, 2)
  discount         Decimal         @default("0") @db.Decimal(12, 2) // non-cash settlement waiver recorded with payment
  paidDate         DateTime        @default(now())
  method           String          @default("CASH")
  note             String?
  recordedBy       User?           @relation("PaymentRecordedBy", fields: [recordedByUserId], references: [id])
  recordedByUserId String?
  createdAt        DateTime        @default(now())

  @@index([agreementId])
  @@index([paidDate])
}

// ----------------------------------------------------------------------------
// Purchasing / supplier credit
// ----------------------------------------------------------------------------

enum PurchaseType {
  CASH
  CREDIT
}

enum PurchaseStatus {
  PAID
  PARTIAL
  CREDIT
}

model Purchase {
  id                String         @id @default(cuid())
  supplier          Supplier       @relation(fields: [supplierId], references: [id])
  supplierId        String
  supplierInvoiceNo String?
  date              DateTime       @default(now())
  type              PurchaseType   @default(CASH)
  total             Decimal        @db.Decimal(12, 2)
  amountPaid        Decimal        @default("0") @db.Decimal(12, 2)
  creditDueDate     DateTime?
  status            PurchaseStatus @default(PAID)
  notes             String?
  createdAt         DateTime       @default(now())

  items         PurchaseItem[]
  payments      PurchasePayment[]
  returns       SupplierReturn[]
  issuedCheques IssuedCheque[]

  @@index([supplierId])
  @@index([creditDueDate])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseId String
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  qty        Int
  costPrice  Decimal  @db.Decimal(12, 2)
  lineTotal  Decimal  @db.Decimal(12, 2)

  @@index([purchaseId])
  @@index([productId])
}

model PurchasePayment {
  id         String   @id @default(cuid())
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseId String
  amount     Decimal  @db.Decimal(12, 2)
  paidDate   DateTime @default(now())
  note       String?
}

// ----------------------------------------------------------------------------
// Banking / supplier cheques
// ----------------------------------------------------------------------------

model BankAccount {
  id             String   @id @default(cuid())
  accountName    String
  bankName       String
  accountNumber  String
  branch         String?
  overdraftLimit Decimal? @db.Decimal(12, 2)
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  issuedCheques IssuedCheque[]

  @@index([active])
  @@index([bankName])
}

model IssuedCheque {
  id            String      @id @default(cuid())
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  bankAccountId String
  supplier      Supplier    @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierId    String
  purchase      Purchase?   @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  purchaseId    String?
  chequeNumber  String
  amount        Decimal     @db.Decimal(12, 2)
  issuedDate    DateTime
  dueDate       DateTime
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  payments ChequePayment[]

  @@unique([bankAccountId, chequeNumber])
  @@index([supplierId])
  @@index([purchaseId])
  @@index([dueDate])
}

model ChequePayment {
  id             String       @id @default(cuid())
  issuedCheque   IssuedCheque @relation(fields: [issuedChequeId], references: [id], onDelete: Cascade)
  issuedChequeId String
  amount         Decimal      @db.Decimal(12, 2)
  paidDate       DateTime     @default(now())
  note           String?
  createdAt      DateTime     @default(now())

  @@index([issuedChequeId, paidDate])
}

// ----------------------------------------------------------------------------
// Payroll & HR
// ----------------------------------------------------------------------------

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

model Attendance {
  id         String           @id @default(cuid())
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
  date       DateTime         @db.Date
  status     AttendanceStatus @default(PRESENT)
  note       String?

  @@unique([employeeId, date])
  @@index([date])
}

model Commission {
  id         String   @id @default(cuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
  amount     Decimal  @db.Decimal(12, 2)
  reason     String
  date       DateTime @default(now())
  invoiceId  String?
  createdAt  DateTime @default(now())

  @@index([employeeId])
  @@index([date])
}

// Extra pay for hours worked beyond normal. Manually entered (like Commission);
// folds into gross pay at payroll but is excluded from the EPF/ETF base.
model Overtime {
  id         String   @id @default(cuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
  date       DateTime @default(now())
  hours      Decimal  @db.Decimal(6, 2)
  rate       Decimal  @db.Decimal(12, 2) // per-hour rate
  amount     Decimal  @db.Decimal(12, 2) // hours x rate, computed at entry
  reason     String?
  createdAt  DateTime @default(now())

  @@index([employeeId])
  @@index([date])
}

enum AdvanceStatus {
  OUTSTANDING
  RECOVERED
}

// Salary paid up front. Auto-recovered (deducted) from a later payroll run,
// oldest-first, whole-or-defer (never partially splits a single advance, and
// never pushes net pay below zero). recoveredRunId links it to the run that
// recovered it so regenerating that run can release it again (idempotent).
model SalaryAdvance {
  id             String        @id @default(cuid())
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId     String
  amount         Decimal       @db.Decimal(12, 2)
  date           DateTime      @default(now())
  note           String?
  status         AdvanceStatus @default(OUTSTANDING)
  recoveredRunId String? // PayrollRun.id that recovered it (loose ref, no FK)
  recoveredAt    DateTime?
  createdAt      DateTime      @default(now())

  @@index([employeeId, status])
}

model PayrollRun {
  id          String        @id @default(cuid())
  period      String        @unique // YYYY-MM
  generatedAt DateTime      @default(now())
  lines       PayrollLine[]
}

model PayrollLine {
  id               String     @id @default(cuid())
  run              PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId            String
  employee         Employee   @relation(fields: [employeeId], references: [id])
  employeeId       String
  daysWorked       Decimal    @db.Decimal(6, 1)
  dailyRate        Decimal    @db.Decimal(12, 2)
  baseSalary       Decimal    @db.Decimal(12, 2)
  overtimeTotal    Decimal    @default("0") @db.Decimal(12, 2)
  commissionsTotal Decimal    @default("0") @db.Decimal(12, 2)
  epfEmployee      Decimal    @default("0") @db.Decimal(12, 2) // 8% deducted from pay
  epfEmployer      Decimal    @default("0") @db.Decimal(12, 2) // 12% employer cost
  etf              Decimal    @default("0") @db.Decimal(12, 2) // 3% employer cost
  advanceDeduction Decimal    @default("0") @db.Decimal(12, 2)
  deductions       Decimal    @default("0") @db.Decimal(12, 2) // epfEmployee + advanceDeduction
  netPay           Decimal    @db.Decimal(12, 2)
}

// ----------------------------------------------------------------------------
// Finance & ops
// ----------------------------------------------------------------------------

model Expense {
  id            String   @id @default(cuid())
  category      String // rent, utilities, bills, salaries, misc
  amount        Decimal  @db.Decimal(12, 2)
  date          DateTime @default(now())
  description   String?
  attachmentKey String?
  createdAt     DateTime @default(now())

  @@index([date])
  @@index([category])
}

enum NotificationType {
  CUSTOMER_PAYMENT
  CUSTOMER_REQUEST
  INTEREST_WARNING
  SUPPLIER_CREDIT
  ADMIN_DIGEST
}

enum NotificationStatus {
  SENT
  FAILED
}

model NotificationLog {
  id        String             @id @default(cuid())
  type      NotificationType
  refId     String? // agreement id, purchase id, etc.
  dedupeKey String?            @unique // prevents duplicate sends per period
  channel   String             @default("SMS")
  recipient String
  message   String
  status    NotificationStatus @default(SENT)
  error     String?
  sentAt    DateTime           @default(now())

  @@index([type])
  @@index([sentAt])
}

// ----------------------------------------------------------------------------
// Stock audit & returns
// ----------------------------------------------------------------------------

enum StockMovementType {
  OPENING
  PURCHASE
  SALE
  SALE_VOID // reversal of an accidental sale — stock in
  RETURN // customer return — stock in
  SUPPLIER_RETURN // returned to supplier — stock out
  ADJUSTMENT
}

// One row per change to a product's stock — the audit trail.
model StockMovement {
  id              String            @id @default(cuid())
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId       String
  type            StockMovementType
  qty             Int // signed: positive = stock in, negative = stock out
  balanceAfter    Int // stock level immediately after this movement
  reason          String?
  refId           String? // invoice / purchase / return id
  createdBy       User?             @relation(fields: [createdByUserId], references: [id])
  createdByUserId String?
  createdAt       DateTime          @default(now())

  @@index([productId])
  @@index([createdAt])
}

enum PriceChangeReason {
  PURCHASE_WAC // cost recalculated as weighted-average on a stock purchase
  MANUAL // cost/price edited directly on the product form
  BULK // changed by the bulk price adjuster
}

// Audit trail for cost/selling-price changes — answers "why did this price move?".
model PriceChange {
  id              String            @id @default(cuid())
  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId       String
  reason          PriceChangeReason
  oldCostPrice    Decimal           @db.Decimal(12, 2)
  newCostPrice    Decimal           @db.Decimal(12, 2)
  oldSellingPrice Decimal           @db.Decimal(12, 2)
  newSellingPrice Decimal           @db.Decimal(12, 2)
  note            String?
  createdBy       User?             @relation(fields: [createdByUserId], references: [id])
  createdByUserId String?
  createdAt       DateTime          @default(now())

  @@index([productId])
  @@index([createdAt])
}

model SalesReturn {
  id              String   @id @default(cuid())
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])
  invoiceId       String?
  date            DateTime @default(now())
  totalRefund     Decimal  @db.Decimal(12, 2)
  method          String   @default("CASH")
  reason          String?
  createdBy       User?    @relation(fields: [createdByUserId], references: [id])
  createdByUserId String?
  createdAt       DateTime @default(now())

  items SalesReturnItem[]

  @@index([invoiceId])
  @@index([createdAt])
}

model SalesReturnItem {
  id           String      @id @default(cuid())
  return       SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  returnId     String
  product      Product     @relation(fields: [productId], references: [id])
  productId    String
  qty          Int
  unitPrice    Decimal     @db.Decimal(12, 2)
  lineTotal    Decimal     @db.Decimal(12, 2)
  // Product cost captured from the original sale (the invoice item's costSnapshot)
  // so the returned goods are credited back to COGS at the same cost they were
  // charged out at. Null on rows created before this field existed — reports fall
  // back to the product's current cost, matching InvoiceItem.costSnapshot.
  costSnapshot Decimal?    @db.Decimal(12, 2)

  @@index([returnId])
}

// Stock returned to a supplier (defective / over-supply / wrong item). Decrements
// stock. `method` = how the value is settled:
//   REDUCE_PAYABLE — credited against the linked purchase's outstanding balance
//   CASH_REFUND    — supplier refunds cash (recorded only, no balance change)
//   REPLACEMENT    — supplier sends replacement goods (recorded only)
// `appliedToPayable` is how much actually reduced the purchase balance (capped at
// the balance), so the money effect is auditable.
model SupplierReturn {
  id               String    @id @default(cuid())
  supplier         Supplier  @relation(fields: [supplierId], references: [id])
  supplierId       String
  purchase         Purchase? @relation(fields: [purchaseId], references: [id])
  purchaseId       String?
  date             DateTime  @default(now())
  totalValue       Decimal   @db.Decimal(12, 2)
  method           String    @default("REDUCE_PAYABLE")
  appliedToPayable Decimal   @default("0") @db.Decimal(12, 2)
  reason           String?
  createdBy        User?     @relation(fields: [createdByUserId], references: [id])
  createdByUserId  String?
  createdAt        DateTime  @default(now())

  items SupplierReturnItem[]

  @@index([supplierId])
  @@index([purchaseId])
  @@index([createdAt])
}

model SupplierReturnItem {
  id        String         @id @default(cuid())
  return    SupplierReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  returnId  String
  product   Product        @relation(fields: [productId], references: [id])
  productId String
  qty       Int
  unitCost  Decimal        @db.Decimal(12, 2)
  lineTotal Decimal        @db.Decimal(12, 2)

  @@index([returnId])
}

// ----------------------------------------------------------------------------
// After-sales service & warranty jobs
// ----------------------------------------------------------------------------

enum ServiceJobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ServiceEventType {
  CREATED
  STATUS_CHANGE
  NOTE
}

// An after-sale service / warranty repair brought in by a customer. Internal
// record only — no money flows through it; any charge is noted in `notes`.
model ServiceJob {
  id        String           @id @default(cuid())
  jobNumber String           @unique // SVC-000001
  status    ServiceJobStatus @default(PENDING)

  itemName      String // e.g. "Refrigerator"
  brand         String? // brand / model
  serialNumber  String?
  underWarranty Boolean  @default(false) // warranty repair vs paid job
  issue         String // reported problem / requested work
  resolution    String? // what was done (filled on completion)
  notes         String? // free text, incl. any cost notes
  photoKeys     String[] @default([]) // storage keys (served via /api/files)

  // optional customer link; falls back to inline contact for walk-ins
  customer     Customer? @relation(fields: [customerId], references: [id])
  customerId   String?
  contactName  String?
  contactPhone String?

  // optional link back to the original sale
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  invoiceId String?

  createdBy       User?     @relation(fields: [createdByUserId], references: [id])
  createdByUserId String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  events ServiceJobEvent[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

// Dated audit timeline for a service job — the "proof" of what happened and when.
model ServiceJobEvent {
  id              String            @id @default(cuid())
  job             ServiceJob        @relation(fields: [serviceJobId], references: [id], onDelete: Cascade)
  serviceJobId    String
  type            ServiceEventType
  status          ServiceJobStatus? // snapshot for STATUS_CHANGE
  note            String?
  createdBy       User?             @relation(fields: [createdByUserId], references: [id])
  createdByUserId String?
  createdAt       DateTime          @default(now())

  @@index([serviceJobId])
}
